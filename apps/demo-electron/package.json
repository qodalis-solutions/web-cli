{
  "name": "demo-electron",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Electron demo app for the Qodalis CLI terminal",
  "main": "out/main/index.js",
  "scripts": {
    "build:main": "tsup src/main/index.ts --format cjs --out-dir out/main --external electron --external @qodalis/electron-cli/main --clean",
    "build:preload": "tsup src/preload/index.ts --format cjs --out-dir out/preload --external electron --external @qodalis/electron-cli/preload --clean",
    "build:renderer": "vite build",
    "build": "pnpm run build:main && pnpm run build:preload && pnpm run build:renderer",
    "start": "electron .",
    "dev:electron": "pnpm run build:main && pnpm run build:preload && concurrently -n vite,electron -c green,blue \"vite\" \"wait-on http://localhost:5173 && ELECTRON_DEV=1 electron .\""
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "@qodalis/react-cli": "workspace:*",
    "@qodalis/electron-cli": "workspace:*",
    "@qodalis/cli": "workspace:*",
    "@qodalis/cli-core": "workspace:*",
    "@qodalis/cli-guid": "workspace:*",
    "@qodalis/cli-regex": "workspace:*",
    "@qodalis/cli-text-to-image": "workspace:*",
    "@qodalis/cli-speed-test": "workspace:*",
    "@qodalis/cli-browser-storage": "workspace:*",
    "@qodalis/cli-string": "workspace:*",
    "@qodalis/cli-todo": "workspace:*",
    "@qodalis/cli-curl": "workspace:*",
    "@qodalis/cli-password-generator": "workspace:*",
    "@qodalis/cli-qr": "workspace:*",
    "@qodalis/cli-yesno": "workspace:*",
    "@qodalis/cli-server-logs": "workspace:*",
    "@qodalis/cli-users": "workspace:*",
    "@qodalis/cli-files": "workspace:*",
    "@qodalis/cli-snake": "workspace:*",
    "@qodalis/cli-tetris": "workspace:*",
    "@qodalis/cli-2048": "workspace:*",
    "@qodalis/cli-minesweeper": "workspace:*",
    "@qodalis/cli-wordle": "workspace:*",
    "@qodalis/cli-scp": "workspace:*",
    "@qodalis/cli-wget": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^8.0.0"
  }
}
