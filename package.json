{
  "name": "qodalis-cli-workspace",
  "version": "2.0.0-beta.10",
  "scripts": {
    "build": "nx run-many -t build",
    "build:affected": "nx affected -t build",
    "build:core": "nx build core",
    "build:cli": "nx build cli",
    "build:angular-cli": "pnpm run build:styles && nx build angular-cli",
    "build:react-cli": "nx build react-cli",
    "build:vue-cli": "nx build vue-cli",
    "build:electron-cli": "nx build electron-cli",
    "build:styles": "sass packages/angular-cli/src/assets/styles.sass packages/angular-cli/src/assets/styles.css --no-source-map",
    "build:styles:watch": "sass --watch packages/angular-cli/src/assets/styles.sass packages/angular-cli/src/assets/styles.css --no-source-map",
    "serve:angular-demo": "nx serve demo-angular",
    "serve:react-demo": "cd apps/demo-react && npx vite --port 4301",
    "serve:minimal-demo": "cd apps/demo-minimal && npx vite --port 4305",
    "serve:vanilla-demo": "cd apps/demo-vanilla && npx vite --port 4304",
    "serve:vue-demo": "cd apps/demo-vue && npx vite --port 4302",
    "serve:electron-demo": "cd apps/demo-electron && pnpm run dev:electron",
    "serve:docs": "nx serve docs",
    "test": "nx run-many -t test -- --watch=false",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"packages/**/*.{ts,html,css,scss}\" \"apps/**/*.{ts,html,css,scss}\"",
    "graph": "nx graph",
    "inject-versions": "node ./tools/inject-versions.js",
    "create-plugin": "nx build create-cli-plugin && node dist/create-cli-plugin/index.js"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@microsoft/signalr": "^8.0.7",
    "@ngx-translate/core": "^16.0.0",
    "@ngx-translate/http-loader": "^16.0.0",
    "@types/prismjs": "^1.26.6",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.8.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "lodash": "^4.17.21",
    "prismjs": "^1.30.0",
    "qr-code-styling": "^1.9.1",
    "rxjs": "~7.8.0",
    "semver": "^7.7.4",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@nx/js": "^22.5.3",
    "@types/jasmine": "~5.1.0",
    "@types/lodash": "^4.17.14",
    "@types/node": "^22.13.11",
    "@types/semver": "^7.7.1",
    "angular-eslint": "19.0.2",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^19.2.0",
    "nx": "^22.5.3",
    "prettier": "^3.4.2",
    "sass": "^1.85.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.27.6",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.30.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.0.0",
      "minimatch@>=10.0.0": ">=10.2.3",
      "flatted": ">=3.4.0",
      "immutable": ">=5.1.5",
      "serialize-javascript": ">=7.0.0",
      "@babel/runtime": ">=7.26.10"
    }
  }
}
