{
  "name": "lang-ja",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/plugins/lang-ja/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsup", "cp package.json ../../../dist/lang-ja/package.json"],
        "cwd": "packages/plugins/lang-ja",
        "parallel": false
      },
      "inputs": ["production", "sharedGlobals"],
      "outputs": ["{workspaceRoot}/dist/lang-ja"]
    }
  }
}
