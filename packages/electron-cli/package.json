{
  "name": "@qodalis/electron-cli",
  "version": "2.0.0-beta.4",
  "description": "Electron integration for the @qodalis CLI terminal engine. Provides native file dialogs, clipboard, and shell integration.",
  "author": "Nicolae Lupei, Qodalis Solutions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qodalis-solutions/web-cli"
  },
  "homepage": "https://qodalis.com",
  "keywords": [
    "electron",
    "cli",
    "qodalis",
    "terminal",
    "web-terminal",
    "xterm",
    "desktop"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "import": "./dist/preload.mjs",
      "require": "./dist/preload.js"
    },
    "./main": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.mjs",
      "require": "./dist/main.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "electron": ">=28.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "dependencies": {
    "@qodalis/cli-core": "workspace:*"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "sideEffects": false
}
